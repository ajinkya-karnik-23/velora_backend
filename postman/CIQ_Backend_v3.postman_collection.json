{
	"info": {
		"name": "CIQ Backend API v2",
		"description": "Controls Internal Quality (CIQ) Backend — Audit Management API\n\nSetup:\n1. Run the \"Login\" request first to get tokens\n2. The access_token is automatically saved to the collection variable\n3. All authenticated requests use {{access_token}} via Bearer auth",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{"key": "base_url", "value": "http://localhost:8000"},
		{"key": "access_token", "value": ""},
		{"key": "user_id", "value": "1"},
		{"key": "client_id", "value": "1"},
		{"key": "version_id", "value": "1"},
		{"key": "cycle_id", "value": "1"},
		{"key": "control_id", "value": "1"},
		{"key": "config_control_id", "value": "1"},
		{"key": "test_id", "value": "1"},
		{"key": "evidence_id", "value": "1"},
		{"key": "log_id", "value": "1"}
	],
	"auth": {
		"type": "bearer",
		"bearer": [{"key": "token", "value": "{{access_token}}", "type": "string"}]
	},
	"item": [
		{
			"name": "Health",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"url": {"raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"]},
						"auth": {"type": "noauth"}
					}
				}
			]
		},
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('access_token', json.access_token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"url": {"raw": "{{base_url}}/api/v1/auth/login-user", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "login-user"]},
						"auth": {"type": "noauth"},
						"header": [{"key": "Content-Type", "value": "application/x-www-form-urlencoded"}],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{"key": "email", "value": "admin@example.com", "type": "text"},
								{"key": "password", "value": "Admin@12345", "type": "text"}
							]
						}
					}
				},
				{
					"name": "Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('access_token', json.access_token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"url": {"raw": "{{base_url}}/api/v1/auth/refresh-token", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "refresh-token"]},
						"auth": {"type": "noauth"}
					}
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"url": {"raw": "{{base_url}}/api/v1/auth/logout-user", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "logout-user"]},
						"auth": {"type": "noauth"}
					}
				},
				{
					"name": "Get Current User (Me)",
					"request": {
						"method": "GET",
						"url": {"raw": "{{base_url}}/api/v1/auth/get-current-user", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "get-current-user"]}
					}
				}
			]
		},
